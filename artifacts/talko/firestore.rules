rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOfficial(uid) {
      return uid == "talko-official";
    }

    // Users can read any profile (needed to render chat partners, search
    // results, etc.) but may only create/update their own document, and may
    // never change their own verified flag.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid) && request.resource.data.isVerified != true;
      allow update: if isSelf(uid) && request.resource.data.isVerified == resource.data.isVerified;
      allow delete: if false;
    }

    // Conversations are strictly 1:1.
    match /conversations/{conversationId} {
      function oldParticipants() {
        return resource.data.participants;
      }
      function isParticipant() {
        return isSignedIn() && request.auth.uid in oldParticipants();
      }
      function isNewParticipant() {
        return isSignedIn() && request.auth.uid in request.resource.data.participants;
      }
      function otherUid() {
        return oldParticipants().removeAll([request.auth.uid])[0];
      }
      function oldUnread(uid) {
        return resource.data.unreadCount[uid] == null ? 0 : resource.data.unreadCount[uid];
      }

      // isSendMessageUpdate: the participant is recording a message they just
      // sent — they may update the preview fields AND must be the declared
      // sender, and may only bump the other participant's unread counter by 1.
      function isSendMessageUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ["lastMessageText", "lastMessageAt", "lastMessageSenderId", "unreadCount"]
          ) &&
          request.resource.data.lastMessageSenderId == request.auth.uid &&
          request.resource.data.unreadCount[otherUid()] == oldUnread(otherUid()) + 1 &&
          request.resource.data.unreadCount[request.auth.uid] == oldUnread(request.auth.uid);
      }

      // isMarkReadUpdate: the participant is clearing their own unread badge —
      // only the unreadCount map may change, only their own key may be touched,
      // and the other participant's count must remain exactly as-is.
      function isMarkReadUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["unreadCount"]) &&
          request.resource.data.unreadCount[request.auth.uid] == 0 &&
          request.resource.data.unreadCount[otherUid()] == oldUnread(otherUid());
      }

      // A participant may only ever: (a) send a message — update preview
      // fields and bump the other's unread count, or (b) mark as read —
      // zero their own unread count and touch nothing else. The participant
      // list may never change via a client update.
      function isValidMetadataUpdate() {
        return request.resource.data.participants == oldParticipants() &&
          (isSendMessageUpdate() || isMarkReadUpdate());
      }

      allow read: if isParticipant();
      allow create: if isNewParticipant() && request.resource.data.participants.size() == 2;
      allow update: if isParticipant() && isValidMetadataUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        function conversationParticipants() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        }

        allow read: if isSignedIn() && request.auth.uid in conversationParticipants();
        // Anyone in the conversation may send a message, EXCEPT nobody may
        // send as the official Talko account other than server-side admin
        // tooling (which uses the Admin SDK and bypasses these rules).
        allow create: if isSignedIn()
          && request.auth.uid in conversationParticipants()
          && request.resource.data.senderId == request.auth.uid
          && !isOfficial(request.auth.uid);
        allow update, delete: if false;
      }

      match /typing/{uid} {
        function conversationParticipants() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        }

        allow read: if isSignedIn() && request.auth.uid in conversationParticipants();
        allow write: if isSelf(uid) && request.auth.uid in conversationParticipants();
      }
    }
  }
}
